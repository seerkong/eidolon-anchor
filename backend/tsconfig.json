{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@cell/core-contract": ["../cell/packages/core-contract/src/index.ts"],
      "@cell/core-contract/*": ["../cell/packages/core-contract/src/*"],
      "@cell/core-logic": ["../cell/packages/core-logic/src/index.ts"],
      "@cell/core-logic/*": ["../cell/packages/core-logic/src/*"],
      "@cell/ai-core-contract": ["../cell/packages/ai-core-contract/src/index.ts"],
      "@cell/ai-core-contract/*": ["../cell/packages/ai-core-contract/src/*"],
      "@cell/mod-platform-kernel": ["../cell/packages/mod-platform-kernel/src/index.ts"],
      "@cell/mod-platform-kernel/*": ["../cell/packages/mod-platform-kernel/src/*"],
      "@cell/symbiont-logic": ["../cell/packages/symbiont-logic/src/index.ts"],
      "@cell/symbiont-logic/*": ["../cell/packages/symbiont-logic/src/*"],
      "@cell/symbiont-contract": ["../cell/packages/symbiont-contract/src/index.ts"],
      "@cell/symbiont-contract/*": ["../cell/packages/symbiont-contract/src/*"],
      "@cell/ai-organ-contract": ["../cell/packages/ai-organ-contract/src/index.ts"],
      "@cell/ai-organ-contract/*": ["../cell/packages/ai-organ-contract/src/*"],
      "@cell/ai-organ-logic": ["../cell/packages/ai-organ-logic/src/index.ts"],
      "@cell/ai-organ-logic/*": ["../cell/packages/ai-organ-logic/src/*"],
      "@cell/platform-support": ["../cell/packages/platform-support/src/index.ts"],
      "@cell/platform-support/*": ["../cell/packages/platform-support/src/*"],
      "@terminal/core": ["../terminal/packages/core/src"],
      "@terminal/core/*": ["../terminal/packages/core/src/*"],
      "@terminal/organ": ["../terminal/packages/organ/src"],
      "@terminal/organ/*": ["../terminal/packages/organ/src/*"],
      "@backend/core/*": ["packages/core/src/*"],
      "@backend/organ/*": ["packages/organ/src/*"],
      "@backend/composer/*": ["packages/composer/src/*"],
      "@backend/elysia-shell/*": ["packages/elysia/src/*"],
      "@backend/koa-shell/*": ["packages/koa/src/*"],
    }
  },
  "include": ["packages/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
