<type_def lang="typescript" ?>
export interface DetachedBashOuterInput {
  command: string;
  agent_type: string;
}

export type DetachedBashOuterOutput = string;

export type DetachedBash = (input: DetachedBashOuterInput) => DetachedBashOuterOutput;
</?>

<warning ?>
This tool starts a detached actor that will execute a single bash command.

The detached actor user prompt is a JSON string: { "command": <command> }.
</?>
