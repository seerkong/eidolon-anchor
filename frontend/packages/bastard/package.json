{
  "name": "ai-architect-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run ../../scripts/ensure-build-runtime.ts && bun run ../../scripts/run-vite.ts",
    "build": "bun run ../../scripts/ensure-build-runtime.ts && bun run ../../scripts/run-vite.ts build",
    "preview": "bun run ../../scripts/ensure-build-runtime.ts && bun run ../../scripts/run-vite.ts preview",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:fast-crud-track": "vitest run --config vitest.config.mjs tests/fast-crud-plugin.test.ts tests/fast-crud-minimal-entry.test.ts tests/fast-crud-scope-guard.test.ts tests/fast-crud-demo-page.test.ts tests/fast-crud-demo-regression.test.ts",
