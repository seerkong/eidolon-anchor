{
  "name": "@frontend/vue-shell",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun run ../../scripts/sync-static.ts vue",
    "dev": "bun run ../../scripts/ensure-build-runtime.ts && bun run ../../scripts/run-vite.ts",
    "prebuild": "bun run ../../scripts/sync-static.ts vue",
    "build": "bun run ../../scripts/ensure-build-runtime.ts && bun run ../../scripts/run-vite.ts build"
  },
  "dependencies": {
    "@tiptap/core": "^3.6.2",
    "@tiptap/starter-kit": "^3.6.2",
    "@tiptap/vue-3": "^3.6.2",
    "@frontend/core": "workspace:*",
    "@frontend/composer": "workspace:*",
    "@shared/composer": "workspace:*",
    "inversify": "^6.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
