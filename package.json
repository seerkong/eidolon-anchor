{
  "name": "eidolon-anchor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend:elysia": "cd backend && bun run dev",
    "dev:backend:koa": "cd backend && bun run dev:koa",
    "build:backend:elysia": "cd backend && bun run build",
    "build:backend:koa": "cd backend && bun run build:koa",
    "dev:frontend:vue": "cd frontend && bun run dev:vue",
    "dev:frontend:react": "cd frontend && bun run dev:react",
    "dev:frontend:bastard": "cd frontend/packages/bastard && bun run dev",
    "build:frontend:vue": "cd frontend && bun run build:vue",
    "build:frontend:react": "cd frontend && bun run build:react",
    "build:frontend:bastard": "cd frontend && bun run build:bastard",
    "test:frontend": "cd frontend && bun run test",
    "test:frontend:core": "cd frontend/packages/core && bun run test",
    "test:frontend:mosaic": "cd frontend/packages/composer && bun run test",
    "test:backend:core": "cd backend/packages/core && bun run test",
    "test:backend:mosaic": "cd backend/packages/composer && bun run test",
    "test:backend": "bun run test:backend:core && bun run test:backend:mosaic",
    "test:terminal:core": "cd terminal/packages/core && bun run test",
    "test:terminal:core:js": "cd terminal/packages/core && bun run test:js",
    "test:terminal:core:native": "cd terminal/packages/core && bun run test:native",
    "test:terminal:tui": "bun run --cwd terminal/packages/tui test",
    "test:terminal": "bun run test:terminal:core:js",
    "test:all": "bun run test:backend && bun run test:frontend && bun run test:terminal",
    "dev:desktop:vue": "cd desktop && FRONTEND_SHELL=vue bun run dev",
    "dev:desktop:react": "cd desktop && FRONTEND_SHELL=react bun run dev",
    "dev:desktop:bastard": "cd desktop && FRONTEND_SHELL=bastard bun run dev",
    "build:web:vue-elysia": "bun run scripts/build-web.ts vue",
    "build:web:react-elysia": "bun run scripts/build-web.ts react",
    "build:web:bastard-elysia": "bun run scripts/build-web.ts bastard",
    "build:web:vue-koa": "bun run scripts/build-web-koa.ts vue",
    "build:web:react-koa": "bun run scripts/build-web-koa.ts react",
    "build:desktop:vue": "bun run build:web:vue-elysia && cd desktop/packages/shell && FRONTEND_SHELL=vue bun run scripts/build-dispatch.ts",
    "build:desktop:react": "bun run build:web:react-elysia && cd desktop/packages/shell && FRONTEND_SHELL=react bun run scripts/build-dispatch.ts",
    "build:desktop:bastard": "bun run build:web:bastard-elysia && cd desktop/packages/shell && FRONTEND_SHELL=bastard bun run scripts/build-dispatch.ts",
    "build:terminal:core": "bun run --cwd terminal/packages/core build",
    "build:terminal:cli": "bun run scripts/build-terminal-cli.ts",
    "build:terminal:tui": "bun run scripts/build-terminal-tui.ts",
    "build:terminal:tui:release": "./scripts/build_tui_release.sh",
    "install:dist:tui": "bun run scripts/install-dist-tui.ts",
    "dev:terminal:cli": "EIDOLON_LAUNCH_CWD=$PWD bun run --cwd terminal/packages/cli dev",
    "dev:terminal:tui": "bun run --cwd terminal/packages/tui dev",
    "install:all:bun": "bun run scripts/install-all.ts",
    "install:all:nodejs": "node scripts/install-all-nodejs.cjs",
    "uninstall:all": "bun run scripts/uninstall-all.ts",
    "dev:web:vue-koa": "concurrently -n frontend,backend -c blue,green \"bun run dev:frontend:vue\" \"bun run dev:backend:koa\"",
    "dev:web:react-koa": "concurrently -n frontend,backend -c blue,green \"bun run dev:frontend:react\" \"bun run dev:backend:koa\""
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.4.0",
    "concurrently": "^9.1.0"
  },
  "workspaces": [
    "cell",
    "cell/packages/*",
    "vendor/*",
    "shared",
    "shared/packages/*",
    "backend",
    "backend/packages/*",
    "desktop",
    "frontend/packages/*",
    "terminal",
    "terminal/packages/*"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "1.1.25",
    "eslint": "^9.39.2"
  },
  "overrides": {
    "node-gyp": "10.0.1",
    "test-exclude": "7.0.1"
  }
}
