{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["@types/bun", "@types/node", "@opentui/solid"],
    "paths": {
      "@terminal/tui": ["./src"],
      "@terminal/tui/*": ["./src/*"],

      "@cell/core-contract": ["../../../cell/packages/core-contract/src/index.ts"],
      "@cell/core-contract/*": ["../../../cell/packages/core-contract/src/*"],
      "@cell/core-logic": ["../../../cell/packages/core-logic/src/index.ts"],
      "@cell/core-logic/*": ["../../../cell/packages/core-logic/src/*"],
      "@cell/ai-core-contract": ["../../../cell/packages/ai-core-contract/src/index.ts"],
      "@cell/ai-core-contract/*": ["../../../cell/packages/ai-core-contract/src/*"],
      "@cell/ai-core-logic": ["../../../cell/packages/ai-core-logic/src/index.ts"],
      "@cell/ai-core-logic/*": ["../../../cell/packages/ai-core-logic/src/*"],
      "@cell/membrane": ["../../../cell/packages/membrane/src/index.ts"],
      "@cell/membrane/*": ["../../../cell/packages/membrane/src/*"],
      "@cell/mod-ai-coding": ["../../../cell/packages/mod-ai-coding/src/index.ts"],
      "@cell/mod-ai-coding/*": ["../../../cell/packages/mod-ai-coding/src/*"],
      "@cell/mod-platform-kernel": ["../../../cell/packages/mod-platform-kernel/src/index.ts"],
      "@cell/mod-platform-kernel/*": ["../../../cell/packages/mod-platform-kernel/src/*"],
      "@cell/mod-ai-kernel": ["../../../cell/packages/mod-ai-kernel/src/index.ts"],
      "@cell/mod-ai-kernel/*": ["../../../cell/packages/mod-ai-kernel/src/*"],
      "@cell/mod-profiles": ["../../../cell/packages/mod-profiles/src/index.ts"],
      "@cell/mod-profiles/*": ["../../../cell/packages/mod-profiles/src/*"],
      "@cell/symbiont-logic": ["../../../cell/packages/symbiont-logic/src/index.ts"],
      "@cell/symbiont-logic/*": ["../../../cell/packages/symbiont-logic/src/*"],
      "@cell/symbiont-contract": ["../../../cell/packages/symbiont-contract/src/index.ts"],
      "@cell/symbiont-contract/*": ["../../../cell/packages/symbiont-contract/src/*"],
      "@cell/ai-organ-contract": ["../../../cell/packages/ai-organ-contract/src/index.ts"],
      "@cell/ai-organ-contract/*": ["../../../cell/packages/ai-organ-contract/src/*"],
      "@cell/ai-organ-logic": ["../../../cell/packages/ai-organ-logic/src/index.ts"],
      "@cell/ai-organ-logic/*": ["../../../cell/packages/ai-organ-logic/src/*"],
      "@cell/platform-contract": ["../../../cell/packages/platform-contract/src/index.ts"],
      "@cell/platform-contract/*": ["../../../cell/packages/platform-contract/src/*"],
      "@cell/ai-support": ["../../../cell/packages/ai-support/src/index.ts"],
      "@cell/ai-support/*": ["../../../cell/packages/ai-support/src/*"],
      "@cell/platform-support": ["../../../cell/packages/platform-support/src/index.ts"],
      "@cell/platform-support/*": ["../../../cell/packages/platform-support/src/*"],
      "@shared/composer": ["../../../shared/packages/composer/src"],
      "@shared/composer/*": ["../../../shared/packages/composer/src/*"]
    }
  },
  "include": ["src", "tests"]
}
